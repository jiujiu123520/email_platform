{
    "name": "email-platform/php",
    "description": "邮件发送平台 PHP 版本",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^6.0",
        "topthink/think-orm": "^2.0",
        "topthink/think-view": "^1.0",
        "ext-pdo_sqlsrv": "*",
        "ext-sqlsrv": "*"
    },
    "require-dev": {
        "symfony VarDumper": "*"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        }
    },
    "config": {
        "preferred-install": "dist"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php think clear"
        ]
    }
}
